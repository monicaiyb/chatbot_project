    "# bot.py\n",
    "\n",
    "from chatterbot import ChatBot\n",
    "\n",
    "chatbot = ChatBot(\"Chatpot\")\n",
    "\n",
    "exit_conditions = (\":q\", \"quit\", \"exit\")\n",
    "while True:\n",
    "    query = input(\"> \")\n",
    "    if query in exit_conditions:\n",
    "        break\n",
    "    else: \n",
    "        print(f\"🪴 {chatbot.get_response(query)}\")"
   ]
